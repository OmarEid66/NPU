        "dir::RTL/*.v",
        "dir::RTL/*.sv",
        "dir::RTL/*.SV"
    ],

    "//": "--- Clock period (ns) — set based on your target frequency ---",
    "CLOCK_PERIOD": 50,
    
    "//": "--- Timing constraint files ---",
    "PNR_SDC_FILE": "dir::pnr.sdc",
    "SIGNOFF_SDC_FILE": "dir::signoff.sdc",
