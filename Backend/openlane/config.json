{
    "//": "================================================================",
    "//": " project_macro — config.json",
    "//": "================================================================",

    "//": "=== USER SECTION — Edit the parameters below for your design ===",

    "//": "--- Verilog source files ---",
    "//": "Add your own RTL files before project_macro.v.",
    
